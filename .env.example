# Weights & Biases Configuration
# Copy this to .env and fill in your values. .env is not committed to git.

# Enable W&B logging (1 = yes, 0 = no)
WANDB_ENABLED=1

# Your W&B workspace entity (username or organization)
WANDB_ENTITY=yoonmeehwang-carnegie-mellon-university

# W&B project name
WANDB_PROJECT=RWML

# Optional: group runs by tag (e.g., "exp1", "baseline")
WANDB_GROUP=

# Optional: give this run a custom name
WANDB_NAME=

# Logging mode: online (default), offline, or disabled
# - online: logs to wandb.com (requires login and API key)
# - offline: logs to local wandb/ directory
# - disabled: no logging
WANDB_MODE=online

# W&B API key (get from https://wandb.ai/authorize)
# Only needed for online mode if not already logged in
# WANDB_API_KEY=your_key_here
